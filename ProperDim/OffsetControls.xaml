<Window x:Class="ProperDim.OffsetControls" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:properdim="clr-namespace:ProperDim;assembly=ProperDim"
        Title="Multi-Display Controls" 
        Width="280" 
        SizeToContent="Height" 
        WindowStartupLocation="CenterOwner" 
        WindowStyle="None" 
        Background="#2D2D2D" 
        SizeChanged="Window_SizeChanged">
	<WindowChrome.WindowChrome>
		<WindowChrome GlassFrameThickness="1" CornerRadius="0" CaptionHeight="0" UseAeroCaptionButtons="False" ResizeBorderThickness="0" />
	</WindowChrome.WindowChrome>
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
				<Setter Property="Background" Value="#00FFFFFF" />
				<Setter Property="Foreground" Value="#FFFFFFFF" />
				<Setter Property="Width" Value="45" />
				<Setter Property="Height" Value="30" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type Button}">
							<Border Background="{TemplateBinding Control.Background}">
								<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
							</Border>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
				<Style.Triggers>
					<Trigger Property="UIElement.IsMouseOver" Value="True">
						<Setter Property="Background" Value="#3F3F46" />
					</Trigger>
				</Style.Triggers>
			</Style>
			<Style x:Key="DarkScrollBarThumb" TargetType="{x:Type Thumb}">
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type Thumb}">
							<Border Background="#555555" CornerRadius="4" Margin="0,2" />
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}">
				<EventSetter Event="PreviewMouseWheel" Handler="ScrollBar_PreviewMouseWheel" />
				<EventSetter Event="PreviewMouseLeftButtonDown" Handler="ScrollBar_PreviewMouseLeftButtonDown" />
				<EventSetter Event="PreviewMouseMove" Handler="ScrollBar_PreviewMouseMove" />
				<EventSetter Event="PreviewMouseLeftButtonUp" Handler="ScrollBar_PreviewMouseLeftButtonUp" />
				<Setter Property="Background" Value="#00FFFFFF" />
				<Setter Property="Height" Value="8" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type ScrollBar}">
							<Grid Name="Bg" Background="#00FFFFFF" SnapsToDevicePixels="True">
								<Track Name="PART_Track" IsEnabled="{TemplateBinding UIElement.IsEnabled}" IsDirectionReversed="False">
									<Track.Thumb>
										<Thumb>
											<Control.Template>
												<ControlTemplate TargetType="{x:Type Thumb}">
													<Border Background="#555555" CornerRadius="4"/>
												</ControlTemplate>
											</Control.Template>
										</Thumb>
									</Track.Thumb>
								</Track>
							</Grid>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="{x:Type CheckBox}" TargetType="{x:Type CheckBox}">
				<Setter Property="Foreground" Value="#FFFFFFFF" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type CheckBox}">
							<BulletDecorator Background="#00FFFFFF">
								<BulletDecorator.Bullet>
									<Grid Width="16" Height="16">
										<Border Name="BoxBorder" Background="#3E3E42" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="2" />
										<Path Name="CheckMark" Visibility="Collapsed" Data="M3,8 L6,11 L13,4" 
                                  Stroke="#D3D3D3" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
									</Grid>
								</BulletDecorator.Bullet>
								<ContentPresenter Margin="5,0,0,0" VerticalAlignment="Center" />
							</BulletDecorator>
							<ControlTemplate.Triggers>
								<Trigger Property="ToggleButton.IsChecked" Value="True">
									<Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
								</Trigger>
								<Trigger Property="UIElement.IsMouseOver" Value="True">
									<Setter TargetName="BoxBorder" Property="Border.BorderBrush" Value="#6D6D72" />
									<Setter TargetName="BoxBorder" Property="Border.Background" Value="#454549" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="{x:Type Slider}" TargetType="{x:Type Slider}">
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type Slider}">
							<Grid Margin="0,5">
								<Border Background="#3E3E42" Width="6" CornerRadius="3" HorizontalAlignment="Center" />
								<Track Name="PART_Track" IsDirectionReversed="False">
									<Track.DecreaseRepeatButton>
										<RepeatButton Command="Slider.DecreaseLarge">
											<RepeatButton.Template>
												<ControlTemplate TargetType="{x:Type RepeatButton}">
													<Border Background="Transparent" />
												</ControlTemplate>
											</RepeatButton.Template>
										</RepeatButton>
									</Track.DecreaseRepeatButton>
									<Track.IncreaseRepeatButton>
										<RepeatButton Command="Slider.IncreaseLarge">
											<RepeatButton.Template>
												<ControlTemplate TargetType="{x:Type RepeatButton}">
													<Border Background="Transparent" />
												</ControlTemplate>
											</RepeatButton.Template>
										</RepeatButton>
									</Track.IncreaseRepeatButton>
									<Track.Thumb>
										<Thumb>
											<Thumb.Template>
												<ControlTemplate TargetType="{x:Type Thumb}">
													<Ellipse Fill="#B8B8B8" Width="18" Height="18" Stroke="#7E7E7E" StrokeThickness="2" />
												</ControlTemplate>
											</Thumb.Template>
										</Thumb>
									</Track.Thumb>
								</Track>
							</Grid>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Border Background="#2D2D2D" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="8">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="30" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<Border Name="TitleBar" Grid.Row="0" Background="#1E1E1E" CornerRadius="7,7,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
				<Grid>
					<TextBlock Text="Multi-Display Controls" Foreground="#AAAAAA" FontSize="12" IsHitTestVisible="False" VerticalAlignment="Center" Margin="10,0" />
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
						<Button Content="✕" Click="Close_Click">
							<Button.Style>
								<Style TargetType="Button">
									<Setter Property="Background" Value="Transparent"/>
									<Setter Property="Foreground" Value="White"/>
									<Setter Property="Width" Value="45"/>
									<Setter Property="Height" Value="30"/>
									<Setter Property="Template">
										<Setter.Value>
											<ControlTemplate TargetType="Button">
												<Border x:Name="ButtonBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="0,7,0,0"
                                SnapsToDevicePixels="True">
													<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
												</Border>
												<ControlTemplate.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter TargetName="ButtonBorder" Property="Background" Value="#E81123"/>
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Setter.Value>
									</Setter>
								</Style>
							</Button.Style>
						</Button>
					</StackPanel>
				</Grid>
			</Border>
			<Grid Row="1" Margin="20">
				<StackPanel Name="MultiDisplayView" Visibility="Collapsed">
					<TextBlock Name="InstructionText" Foreground="#FF909090" TextAlignment="Center" FontStyle="Italic" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,15">Adjust each display to visually match the brightness of your DIMMEST display.</TextBlock>
					<TextBlock Name="InstructionTextIndependent" Foreground="#FF909090" TextAlignment="Center" FontStyle="Italic" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,15" Visibility="Collapsed">Adjust the brightness of each display separately.</TextBlock>
					<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,10">
						<ItemsControl Name="MonitorsItemsControl" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,5" MinHeight="140">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<UniformGrid Rows="1" HorizontalAlignment="Center" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<StackPanel Orientation="Vertical" Margin="15,0,15,0" Width="80" Background="Transparent" PreviewMouseWheel="MonitorColumn_PreviewMouseWheel">
										<TextBlock Text="{Binding ElementName=MonitorSlider, Path=Value, StringFormat={}{0:P0}}" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10" />
										<Slider Name="MonitorSlider" Orientation="Vertical" Minimum="0.05" Maximum="1.0" Value="{Binding Offset, Mode=OneWay}" Height="100" Width="60" VerticalAlignment="Stretch" SmallChange="0.01" Tag="{Binding}" PreviewMouseLeftButtonDown="OffsetSlider_PreviewMouseLeftButtonDown" PreviewMouseMove="OffsetSlider_PreviewMouseMove" PreviewMouseLeftButtonUp="OffsetSlider_PreviewMouseLeftButtonUp" ValueChanged="MonitorSlider_ValueChanged" Thumb.DragStarted="MonitorSlider_DragStarted" Thumb.DragCompleted="MonitorSlider_DragCompleted" />
										<Canvas Width="70" Height="20" ClipToBounds="True" Margin="0,10,0,0" HorizontalAlignment="Center" Background="Transparent">
											<TextBlock Text="{Binding FriendlyName, TargetNullValue='Display'}" Foreground="Gray" FontSize="11" Canvas.Top="2" ToolTip="{Binding DeviceName}" Loaded="MonitorName_Loaded" />
										</Canvas>
									</StackPanel>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
					<CheckBox Name="SyncBrightnessCheckBox" Content="Synchronize brightness adjustments" FontSize="12" Margin="15,0,0,10"  HorizontalAlignment="Left" Checked="SyncBrightness_Checked" Unchecked="SyncBrightness_Unchecked" />
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
						<Button Content="Reset" Width="75" Height="25" Margin="0,0,16,0" Background="#993333" Cursor="Hand" Click="Reset_Click">
							<Button.Style>
								<Style TargetType="{x:Type Button}">
									<Setter Property="Foreground" Value="White" />
									<Setter Property="Template">
										<Setter.Value>
											<ControlTemplate TargetType="{x:Type Button}">
												<Border Name="BtnBorder" Background="{TemplateBinding Background}" BorderBrush="#555" BorderThickness="1" CornerRadius="0">
													<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter TargetName="BtnBorder" Property="Background" Value="IndianRed" />
														<Setter TargetName="BtnBorder" Property="BorderBrush" Value="#6D6D72" />
														<Setter Property="Foreground" Value="#232324" />
													</Trigger>
													<Trigger Property="IsPressed" Value="True">
														<Setter TargetName="BtnBorder" Property="Background" Value="#A0A0A0" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Setter.Value>
									</Setter>
								</Style>
							</Button.Style>
						</Button>
						<Button Content="Apply" Width="75" Height="25" Background="#3E3E42" Foreground="#FFFFFFFF" BorderBrush="#555" BorderThickness="1" Cursor="Hand" Click="Apply_Click">
							<Button.Template>
								<ControlTemplate TargetType="{x:Type Button}">
									<Border Name="BtnBorder" Background="{TemplateBinding Background}" BorderBrush="#555" BorderThickness="1" CornerRadius="0">
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="BtnBorder" Property="Background" Value="#4E4E52" />
											<Setter TargetName="BtnBorder" Property="BorderBrush" Value="#6D6D72" />
										</Trigger>
										<Trigger Property="IsPressed" Value="True">
											<Setter TargetName="BtnBorder" Property="Background" Value="#2D2D2D" />
										</Trigger>
										<Trigger Property="IsEnabled" Value="False">
											<Setter Property="Opacity" Value="0.5" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</StackPanel>
				</StackPanel>
				<StackPanel Name="NoDisplayView" Visibility="Collapsed">
					<TextBlock Text="No secondary displays detected." FontSize="13" FontWeight="SemiBold" Foreground="#FFCD5C5C" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,20" />
					<TextBlock Name="WaitingForDisplaysText" Text="Waiting for displays." FontSize="11" Foreground="#FF808080" HorizontalAlignment="Center" FontStyle="Italic" Margin="0,-15,0,15" />
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
						<StackPanel.Resources>
							<Style TargetType="{x:Type Button}">
								<Setter Property="Foreground" Value="#FFFFFFFF" />
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="{x:Type Button}">
											<Border Name="BtnBorder" Background="{TemplateBinding Background}" BorderBrush="#555" BorderThickness="1" CornerRadius="0">
												<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="BtnBorder" Property="Background" Value="#4E4E52" />
													<Setter TargetName="BtnBorder" Property="BorderBrush" Value="#6D6D72" />
												</Trigger>
												<Trigger Property="IsPressed" Value="True">
													<Setter TargetName="BtnBorder" Property="Background" Value="#2D2D2D" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</StackPanel.Resources>
						<Button Content="Okay" Width="75" Height="25" Background="#3E3E42" Click="Close_Click" />
					</StackPanel>
				</StackPanel>
			</Grid>
		</Grid>
	</Border>
</Window>