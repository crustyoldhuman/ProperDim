<Window x:Class="ProperDim.AppInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProperDim Info" 
        Height="384" Width="320"
        MinHeight="384" MaxHeight="384"
		MinWidth="320" MaxWidth="320"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen">
	<WindowChrome.WindowChrome>
		<WindowChrome GlassFrameThickness="1" CornerRadius="0" CaptionHeight="0" UseAeroCaptionButtons="False" ResizeBorderThickness="0" />
	</WindowChrome.WindowChrome>

	<Border Background="#252525">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="30"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Grid.Row="0" Background="#1E1E1E" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
				<Grid>
					<TextBlock Text="ProperDim Info" FontSize="12" VerticalAlignment="Center" Margin="15,0,0,0" 
                               Foreground="#AAAAAA" />
					<Button Content="✕" HorizontalAlignment="Right" Width="40" Height="30"
                            Background="Transparent" Foreground="White" BorderThickness="0"
                            Click="Close_Click" Cursor="Hand">
						<Button.Style>
							<Style TargetType="Button">
								<Setter Property="FocusVisualStyle" Value="{StaticResource GrayFocusVisual}" />
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="Button">
											<Border x:Name="ButtonBorder" Background="{TemplateBinding Background}">
												<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="ButtonBorder" Property="Background" Value="#E81123"/>
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</Button.Style>
					</Button>
				</Grid>
			</Border>

			<StackPanel Grid.Row="1" Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center">
				<Image Source="ProperDimIcon.ico" Width="65" Height="65" HorizontalAlignment="Center" Margin="0,0,0,0"/>
				<TextBlock Text="ProperDim" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
				<TextBlock Text="Version 1.4.1" FontSize="11" FontWeight="SemiBold" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,0"/>

				<TextBlock HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Hyperlink NavigateUri="https://github.com/crustyoldhuman/ProperDim" Foreground="#007ACC" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="https://github.com/crustyoldhuman/ProperDim"/>
                    </Hyperlink>
				</TextBlock>

				<TextBlock Text="Created on January 15th, 2026" Foreground="#CCC" HorizontalAlignment="Center"/>
				<TextBlock Text="By Kevin Stanislawski" Foreground="#CCC" HorizontalAlignment="Center" Margin="0,2,0,8"/>

				<TextBlock Text="Like weird games? Check out crustyoldhuman:" Foreground="#FF909090" HorizontalAlignment="Center" FontSize="11"/>
				<TextBlock HorizontalAlignment="Center" Margin="0,2,0,0">
                    <Hyperlink NavigateUri="https://www.twitch.tv/crustyoldhuman" Foreground="#007ACC" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="twitch.tv/crustyoldhuman"/>
                    </Hyperlink>
				</TextBlock>
				<TextBlock HorizontalAlignment="Center" Margin="0,2,0,10">
                    <Hyperlink NavigateUri="https://www.youtube.com/@crustyoldhuman" Foreground="#007ACC" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="youtube.com/@crustyoldhuman"/>
                    </Hyperlink>
				</TextBlock>

				<TextBlock Text="If you like ProperDim..." Foreground="#FF909090" HorizontalAlignment="Center" FontSize="11"/>
				<TextBlock HorizontalAlignment="Center" Margin="0,2,0,15">
                    <Hyperlink NavigateUri="https://www.paypal.com/ncp/payment/8DA8GZKVFPUBN" Foreground="#007ACC" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="...maybe throw me a coffee?"/>
                    </Hyperlink>
				</TextBlock>

				<Button Content="Cool" Width="70" Height="25" Click="Close_Click" Foreground="White">
					<Button.Template>
						<ControlTemplate TargetType="{x:Type Button}">
							<Border Name="BtnBorder" Background="#3E3E42" BorderBrush="#555" BorderThickness="1" CornerRadius="0">
								<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="BtnBorder" Property="Background" Value="#4E4E52" />
									<Setter TargetName="BtnBorder" Property="BorderBrush" Value="#6D6D72" />
								</Trigger>
								<Trigger Property="IsPressed" Value="True">
									<Setter TargetName="BtnBorder" Property="Background" Value="#2D2D2D" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Button.Template>
				</Button>
			</StackPanel>
		</Grid>
	</Border>
</Window>