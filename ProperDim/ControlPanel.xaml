<Window x:Class="ProperDim.ControlPanel" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:properdim="clr-namespace:ProperDim"
        Title="ProperDim Control Panel" 
        Height="200" Width="350" 
        MinHeight="200" MaxHeight="200"
        MinWidth="350" MaxWidth="350"
        WindowStyle="None" 
        Background="#2D2D2D" 
        WindowStartupLocation="Manual" 
        ShowInTaskbar="False" 
        LocationChanged="Window_LocationChanged" 
        Closing="Window_Closing" 
        Loaded="Window_Loaded">
	<WindowChrome.WindowChrome>
		<WindowChrome GlassFrameThickness="1" CornerRadius="0" CaptionHeight="0" UseAeroCaptionButtons="False" ResizeBorderThickness="0" />
	</WindowChrome.WindowChrome>
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
				<Setter Property="Background" Value="#00FFFFFF" />
				<Setter Property="Foreground" Value="#FFFFFFFF" />
				<Setter Property="Width" Value="45" />
				<Setter Property="Height" Value="30" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type Button}">
							<Border Background="{TemplateBinding Control.Background}">
								<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
							</Border>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
				<Style.Triggers>
					<Trigger Property="UIElement.IsMouseOver" Value="True">
						<Setter Property="Background" Value="#3F3F46" />
					</Trigger>
				</Style.Triggers>
			</Style>
			<Style x:Key="TitleBarCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TitleBarButtonStyle}">
				<Style.Triggers>
					<Trigger Property="UIElement.IsMouseOver" Value="True">
						<Setter Property="Background" Value="#E81123" />
					</Trigger>
				</Style.Triggers>
			</Style>
			<Style x:Key="ModernScrollBar" TargetType="{x:Type ScrollBar}">
				<EventSetter Event="PreviewMouseLeftButtonDown" Handler="ScheduleScrollBar_PreviewMouseLeftButtonDown" />
				<EventSetter Event="PreviewMouseMove" Handler="ScheduleScrollBar_PreviewMouseMove" />
				<EventSetter Event="PreviewMouseLeftButtonUp" Handler="ScheduleScrollBar_PreviewMouseLeftButtonUp" />
				<Setter Property="Width" Value="8" />
				<Setter Property="Background" Value="#00FFFFFF" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type ScrollBar}">
							<Grid Background="{TemplateBinding Control.Background}">
								<Track Name="PART_Track" IsDirectionReversed="True">
									<Track.DecreaseRepeatButton>
										<RepeatButton Command="ScrollBar.PageUpCommand">
											<RepeatButton.Template>
												<ControlTemplate TargetType="{x:Type RepeatButton}">
													<Border Background="Transparent" />
												</ControlTemplate>
											</RepeatButton.Template>
										</RepeatButton>
									</Track.DecreaseRepeatButton>
									<Track.IncreaseRepeatButton>
										<RepeatButton Command="ScrollBar.PageDownCommand">
											<RepeatButton.Template>
												<ControlTemplate TargetType="{x:Type RepeatButton}">
													<Border Background="Transparent" />
												</ControlTemplate>
											</RepeatButton.Template>
										</RepeatButton>
									</Track.IncreaseRepeatButton>
									<Track.Thumb>
										<Thumb>
											<Control.Template>
												<ControlTemplate TargetType="{x:Type Thumb}">
													<Border Background="#555555" CornerRadius="4" Margin="1,0" />
												</ControlTemplate>
											</Control.Template>
										</Thumb>
									</Track.Thumb>
								</Track>
							</Grid>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="{x:Type CheckBox}" TargetType="{x:Type CheckBox}">
				<Setter Property="Foreground" Value="#FFFFFFFF" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type CheckBox}">
							<BulletDecorator Background="#00FFFFFF">
								<BulletDecorator.Bullet>
									<Grid Width="16" Height="16">
										<Border Name="BoxBorder" Background="#3E3E42" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="2" />
										<Path Name="CheckMark" Visibility="Collapsed" Data="M3,8 L6,11 L13,4" 
                                  Stroke="#D3D3D3" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
									</Grid>
								</BulletDecorator.Bullet>
								<ContentPresenter Margin="5,0,0,0" VerticalAlignment="Center" />
							</BulletDecorator>
							<ControlTemplate.Triggers>
								<Trigger Property="ToggleButton.IsChecked" Value="True">
									<Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
								</Trigger>
								<Trigger Property="UIElement.IsMouseOver" Value="True">
									<Setter TargetName="BoxBorder" Property="Border.BorderBrush" Value="#6D6D72" />
									<Setter TargetName="BoxBorder" Property="Border.Background" Value="#454549" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="{x:Type TabItem}" TargetType="{x:Type TabItem}">
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type TabItem}">
							<Border Name="Border" Margin="2,0,2,-1" Padding="10,5" CornerRadius="3,3,0,0" Background="#3E3E42" BorderBrush="#3F3F46" BorderThickness="1,1,1,0">
								<ContentPresenter Name="ContentSite" ContentSource="Header" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="TabItem.IsSelected" Value="True">
									<Setter TargetName="Border" Property="Border.Background" Value="#2D2D2D" />
									<Setter TargetName="Border" Property="Border.BorderThickness" Value="1,1,1,0" />
									<Setter Property="Panel.ZIndex" Value="100" />
									<Setter Property="Foreground" Value="#FFD3D3D3" />
								</Trigger>
								<Trigger Property="TabItem.IsSelected" Value="False">
									<Setter Property="Foreground" Value="#FF808080" />
									<Setter TargetName="Border" Property="Margin" Value="2,0,2,0" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="{x:Type TabControl}" TargetType="{x:Type TabControl}">
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type TabControl}">
							<Grid KeyboardNavigation.TabNavigation="Local">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="*" />
								</Grid.RowDefinitions>
								<ItemsPresenter Name="HeaderPanel" Grid.Row="0" Margin="2,2,2,0" Panel.ZIndex="1" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
								<Border Name="ContentBorder" Grid.Row="1" Background="{TemplateBinding Background}" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="0,3,3,3">
									<ContentPresenter ContentSource="SelectedContent" />
								</Border>
							</Grid>
							<ControlTemplate.Triggers>
								<Trigger Property="Selector.SelectedIndex" Value="-1">
									<Setter TargetName="ContentBorder" Property="Visibility" Value="Collapsed" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="{x:Type Slider}" TargetType="{x:Type Slider}">
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type Slider}">
							<Grid Margin="5,0">
								<Border Background="#3E3E42" Height="6" CornerRadius="3" VerticalAlignment="Center" />
								<Track Name="PART_Track" IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
									<Track.DecreaseRepeatButton>
										<RepeatButton Command="Slider.DecreaseLarge">
											<RepeatButton.Template>
												<ControlTemplate TargetType="{x:Type RepeatButton}">
													<Border Background="Transparent" />
												</ControlTemplate>
											</RepeatButton.Template>
										</RepeatButton>
									</Track.DecreaseRepeatButton>
									<Track.IncreaseRepeatButton>
										<RepeatButton Command="Slider.IncreaseLarge">
											<RepeatButton.Template>
												<ControlTemplate TargetType="{x:Type RepeatButton}">
													<Border Background="Transparent" />
												</ControlTemplate>
											</RepeatButton.Template>
										</RepeatButton>
									</Track.IncreaseRepeatButton>
									<Track.Thumb>
										<Thumb>
											<Thumb.Template>
												<ControlTemplate TargetType="{x:Type Thumb}">
													<Ellipse Fill="#B8B8B8" Width="18" Height="18" Stroke="#7E7E7E" StrokeThickness="2" Cursor="Hand" />
												</ControlTemplate>
											</Thumb.Template>
										</Thumb>
									</Track.Thumb>
								</Track>
							</Grid>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="RoundedAddButton" TargetType="{x:Type Button}">
				<Setter Property="Background" Value="#3E3E42" />
				<Setter Property="Foreground" Value="#FFFFFFFF" />
				<Setter Property="BorderBrush" Value="#3F3F46" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type Button}">
							<Border Name="border" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="1" CornerRadius="13">
								<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="UIElement.IsMouseOver" Value="True">
									<Setter TargetName="border" Property="Border.Background" Value="#4E4E52" />
									<Setter TargetName="border" Property="Border.BorderBrush" Value="#6D6D72" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="HotkeyTextBoxStyle" TargetType="{x:Type TextBox}">
				<Setter Property="Background" Value="#3E3E42" />
				<Setter Property="Foreground" Value="#FFFFFFFF" />
				<Setter Property="BorderBrush" Value="#3F3F46" />
				<Setter Property="BorderThickness" Value="1" />
				<Setter Property="Padding" Value="5,2" />
				<Setter Property="VerticalContentAlignment" Value="Center" />
				<Setter Property="HorizontalContentAlignment" Value="Center" />
				<Setter Property="Width" Value="130" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type TextBox}">
							<Border Name="border" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="0">
								<ScrollViewer Name="PART_ContentHost" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="UIElement.IsFocused" Value="True">
									<Setter TargetName="border" Property="Border.BorderBrush" Value="#6D6D72" />
								</Trigger>
								<Trigger Property="IsEnabled" Value="False">
									<Setter Property="Foreground" Value="#FF808080" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Border Background="#2D2D2D" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="8">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="30" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<Border Name="TitleBar" Grid.Row="0" Background="#1E1E1E" CornerRadius="7,7,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
				<Grid>
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
						<Image Source="ProperDimIcon.ico" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center" />
						<TextBlock Text="ProperDim" Foreground="#AAAAAA" FontSize="12" IsHitTestVisible="False" VerticalAlignment="Center" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
						<Button Content="−" Style="{StaticResource TitleBarButtonStyle}" Click="Minimize_Click" />
						<Button Content="✕" Click="Close_Click">
							<Button.Style>
								<Style TargetType="Button">
									<Setter Property="Background" Value="Transparent"/>
									<Setter Property="Foreground" Value="White"/>
									<Setter Property="Width" Value="45"/>
									<Setter Property="Height" Value="30"/>
									<Setter Property="Template">
										<Setter.Value>
											<ControlTemplate TargetType="Button">
												<Border x:Name="ButtonBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="0,7,0,0"
                                SnapsToDevicePixels="True">
													<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
												</Border>
												<ControlTemplate.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter TargetName="ButtonBorder" Property="Background" Value="#E81123"/>
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Setter.Value>
									</Setter>
								</Style>
							</Button.Style>
						</Button>
					</StackPanel>
				</Grid>
			</Border>
			<Grid Row="1" Margin="5" PreviewMouseWheel="TabsArea_MouseWheel">
				<TabControl Name="MainTabs" Background="#2D2D2D" HorizontalContentAlignment="Stretch">
					<TabControl.ItemsPanel>
						<ItemsPanelTemplate>
							<DockPanel LastChildFill="False" Background="Transparent" />
						</ItemsPanelTemplate>
					</TabControl.ItemsPanel>

					<TabItem Header="Controls" DockPanel.Dock="Left">
						<Grid Background="#00FFFFFF" MouseWheel="DimmerSlider_MouseWheel">
							<StackPanel Margin="20,12,20,0">
								<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
									<TextBlock Foreground="#FFFFFFFF" FontSize="14" FontWeight="SemiBold" Text="Brightness Level: " />
									<TextBlock Foreground="#FFFFFFFF" FontSize="14" FontWeight="SemiBold" Text="{Binding ElementName=DimmerSlider, Path=Value, StringFormat={}{0:P0}}" />
								</StackPanel>
								<Slider Name="DimmerSlider" Margin="0,2,0,12" Minimum="0.00" 
									Maximum="1.0" Value="1.0" IsDirectionReversed="False" 
									ValueChanged="Slider_ValueChanged"
									PreviewMouseLeftButtonDown="DimmerSlider_PreviewMouseLeftButtonDown"
									PreviewMouseMove="DimmerSlider_PreviewMouseMove"
									PreviewMouseLeftButtonUp="DimmerSlider_PreviewMouseLeftButtonUp" />
								<UniformGrid Columns="6" Margin="0,2,0,0">
									<UniformGrid.Resources>
										<Style TargetType="{x:Type Button}">
											<Setter Property="Background" Value="#3E3E42" />
											<Setter Property="Foreground" Value="#FFFFFFFF" />
											<Setter Property="FontWeight" Value="SemiBold" />
											<Setter Property="BorderBrush" Value="#555555" />
											<Setter Property="Height" Value="22" />
											<Setter Property="BorderThickness" Value="1" />
											<Setter Property="Cursor" Value="Hand" />
											<Setter Property="Padding" Value="1" />
											<Setter Property="HorizontalContentAlignment" Value="Center" />
											<Setter Property="VerticalContentAlignment" Value="Center" />
											<Setter Property="Template">
												<Setter.Value>
													<ControlTemplate TargetType="{x:Type Button}">
														<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="0">
															<ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
														</Border>
														<ControlTemplate.Triggers>
															<Trigger Property="IsMouseOver" Value="True">
																<Setter TargetName="border" Property="Background" Value="#D3D3D3" />
																<Setter Property="Foreground" Value="#2D2D2D" />
															</Trigger>
															<Trigger Property="IsPressed" Value="True">
																<Setter TargetName="border" Property="Background" Value="#A0A0A0" />
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Setter.Value>
											</Setter>
										</Style>
									</UniformGrid.Resources>
									<Button Content="20%" Tag="0.2" Margin="2" Click="QuickSet_Click" />
									<Button Content="33%" Tag="0.33" Margin="2" Click="QuickSet_Click" />
									<Button Content="50%" Tag="0.5" Margin="2" Click="QuickSet_Click" />
									<Button Content="66%" Tag="0.66" Margin="2" Click="QuickSet_Click" />
									<Button Content="75%" Tag="0.75" Margin="2" Click="QuickSet_Click" />
									<Button Content="100%" Tag="1.0" Margin="2" Click="QuickSet_Click" />
								</UniformGrid>
							</StackPanel>

							<TextBlock HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,6">
								<Hyperlink Name="MinBrightnessLink" Foreground="#FF909090" FontSize="12" TextDecorations="Underline" Click="MinBrightnessLink_Click">
									<Run Text="Adjust Minimum" />
								</Hyperlink>
							</TextBlock>

						</Grid>
					</TabItem>
					<TabItem Header="Schedule">
						<Grid Background="#00FFFFFF" Margin="10,8,10,5">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="*" />
							</Grid.RowDefinitions>
							<Grid Row="0" Margin="0,0,0,0">
								<CheckBox Name="ScheduleCheckbox" 
										  Content="Enable Schedule" 
										  HorizontalAlignment="Left"
										  Margin="2,0,0,0" 
										  VerticalAlignment="Center"
										  FontWeight="SemiBold"
										  Checked="ScheduleCheckbox_Checked" 
										  Unchecked="ScheduleCheckbox_Unchecked" />
								<Button Name="AddScheduleButton" Style="{StaticResource RoundedAddButton}" Content="+" FontSize="14" FontWeight="SemiBold" Width="25" Height="25" Margin="0,-1,4,0" Background="#3E3E42" VerticalAlignment="Center" HorizontalAlignment="Right" ToolTip="Add New Schedule" Click="AddSchedule_Click" />
							</Grid>
							<Grid Grid.Row="1" Margin="0,1,0,-3">
								<TextBlock Name="NoSchedulesText" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Margin="0,0,0,15" FontStyle="Italic" Foreground="#FF808080" IsHitTestVisible="False">No events scheduled...<LineBreak />Press "+" on the top right to add an event</TextBlock>
								<ListBox Name="ScheduleListBox" Background="#00FFFFFF" BorderThickness="0" Foreground="#FFFFFFFF" Margin="0,2,0,0" AlternationCount="2" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="True" VirtualizingPanel.ScrollUnit="Pixel" MouseDoubleClick="ScheduleList_MouseDoubleClick" PreviewMouseWheel="ScheduleList_PreviewMouseWheel">
									<ListBox.ItemsPanel>
										<ItemsPanelTemplate>
											<VirtualizingStackPanel Name="ScheduleStackPanel" />
										</ItemsPanelTemplate>
									</ListBox.ItemsPanel>
									<FrameworkElement.Resources>
										<ResourceDictionary>
											<Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ModernScrollBar}" />
										</ResourceDictionary>
									</FrameworkElement.Resources>
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<Border BorderBrush="#3F3F46" BorderThickness="0,0,0,0" Padding="5,1">
												<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
													<Button Content="✕" Width="18" Height="18" Margin="0,0,10,0" Background="#00FFFFFF" Foreground="#FF5555" BorderThickness="0" Cursor="Hand" ToolTip="Delete Schedule" VerticalAlignment="Center" Click="DeleteSchedule_Click">
														<Control.Template>
															<ControlTemplate TargetType="{x:Type Button}">
																<Border Background="#00FFFFFF">
																	<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
																</Border>
															</ControlTemplate>
														</Control.Template>
													</Button>
													<TextBlock Width="60" Foreground="#FFD3D3D3" VerticalAlignment="Center" FontSize="11" Text="{Binding DisplayTime}" />
													<TextBlock Width="45" Foreground="#FFD3D3D3" VerticalAlignment="Center" FontSize="11" Text="{Binding Display}" />
													<TextBlock Foreground="#FFD3D3D3" FontSize="10" VerticalAlignment="Center" Margin="5,0,0,0" Text="{Binding Days}" />
												</StackPanel>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
									<ItemsControl.ItemContainerStyle>
										<Style TargetType="{x:Type ListBoxItem}">
											<Setter Property="HorizontalContentAlignment" Value="Stretch" />
											<Setter Property="Padding" Value="0" />
											<Setter Property="Background" Value="#292929" />
											<Setter Property="Template">
												<Setter.Value>
													<ControlTemplate TargetType="{x:Type ListBoxItem}">
														<Border Name="Bd" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" Padding="{TemplateBinding Control.Padding}" SnapsToDevicePixels="True">
															<ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}" SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" />
														</Border>
														<ControlTemplate.Triggers>
															<Trigger Property="UIElement.IsMouseOver" Value="True">
																<Setter TargetName="Bd" Property="Border.Background" Value="#44444A" />
															</Trigger>
															<Trigger Property="ListBoxItem.IsSelected" Value="True">
																<Setter TargetName="Bd" Property="Border.Background" Value="#505055" />
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Setter.Value>
											</Setter>
											<Style.Triggers>
												<Trigger Property="ItemsControl.AlternationIndex" Value="1">
													<Setter Property="Background" Value="#313131" />
												</Trigger>
											</Style.Triggers>
										</Style>
									</ItemsControl.ItemContainerStyle>
								</ListBox>
							</Grid>
						</Grid>
					</TabItem>
					<TabItem Header="Hotkeys">
						<Grid Background="Transparent" MouseDown="HotkeysTab_MouseDown" Focusable="True" FocusVisualStyle="{x:Null}">
							<Grid VerticalAlignment="Center" HorizontalAlignment="Center">
								<StackPanel Width="280" Margin="0,8,32,0">
									<CheckBox Name="EnableHotkeysCheckBox" Content="Enable Hotkeys" Margin="0,0,0,8" FontWeight="SemiBold" HorizontalAlignment="Left" Checked="EnableHotkeysCheckBox_Changed" Unchecked="EnableHotkeysCheckBox_Changed" />
									<StackPanel IsEnabled="{Binding ElementName=EnableHotkeysCheckBox, Path=IsChecked}">
										<FrameworkElement.Style>
											<Style TargetType="{x:Type StackPanel}">
												<Style.Triggers>
													<Trigger Property="IsEnabled" Value="False">
														<Setter Property="UIElement.Opacity" Value="0.4" />
													</Trigger>
												</Style.Triggers>
											</Style>
										</FrameworkElement.Style>
										<Grid Margin="0,0,0,0">
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="*" />
												<ColumnDefinition Width="Auto" />
											</Grid.ColumnDefinitions>
											<TextBlock Text="Increase Brightness:" Foreground="#FFFFFFFF" VerticalAlignment="Center" Margin="0,0,10,0" HorizontalAlignment="Right" />
											<TextBox Name="IncreaseHotkeyText" Grid.Column="1" Style="{StaticResource HotkeyTextBoxStyle}" IsReadOnly="True" PreviewKeyDown="HotkeyTextBox_PreviewKeyDown" />
										</Grid>
										<Grid Margin="0,8,0,12">
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="*" />
												<ColumnDefinition Width="Auto" />
											</Grid.ColumnDefinitions>
											<TextBlock Text="Decrease Brightness:" Foreground="#FFFFFFFF" VerticalAlignment="Center" Margin="0,0,10,0" HorizontalAlignment="Right" />
											<TextBox Name="DecreaseHotkeyText" Grid.Column="1" Style="{StaticResource HotkeyTextBoxStyle}" IsReadOnly="True" PreviewKeyDown="HotkeyTextBox_PreviewKeyDown" />
										</Grid>
										<TextBlock Text="Click a field, then press desired keys" Foreground="#FF909090" FontSize="11" FontStyle="Italic" FontWeight="SemiBold" TextAlignment="Center" Margin="22,0,0,8" />
									</StackPanel>
								</StackPanel>
							</Grid>
						</Grid>
					</TabItem>
					<TabItem Header="Options" DockPanel.Dock="Right">
						<Grid Margin="0,0,0,0">

							<StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="34,12,0,0">
								<CheckBox Name="StartupCheckBox" 
										  Content="Run ProperDim when Windows starts" 
										  Margin="0,0,0,4" 
										  Checked="StartupCheckBox_Changed" 
										  Unchecked="StartupCheckBox_Changed" />

								<CheckBox Name="TrayCheckBox" 
										  Content="Close button minimizes to system tray" 
										  Margin="0,0,0,4" 
										  Checked="TrayCheckBox_Changed" 
										  Unchecked="TrayCheckBox_Changed" />

								<CheckBox Name="ShowStartupCheckBox" 
										  Content="Show Controls window on app startup" 
										  Margin="0,0,0,4"
										  Checked="ShowStartupCheckBox_Changed" 
										  Unchecked="ShowStartupCheckBox_Changed" />

								<CheckBox Name="SwapTrayClicksCheckBox" 
										  Content="Swap tray icon left/right click buttons" 
										  Margin="0,0,0,4"
										  Checked="SwapTrayClicksCheckBox_Changed" 
										  Unchecked="SwapTrayClicksCheckBox_Changed" />
							</StackPanel>

							<UniformGrid Columns="2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,6">
								<UniformGrid.Resources>
									<Style TargetType="{x:Type Button}">
										<Setter Property="Foreground" Value="#FFFFFFFF" />
										<Setter Property="BorderBrush" Value="#555555" />
										<Setter Property="BorderThickness" Value="1" />
										<Setter Property="HorizontalContentAlignment" Value="Center" />
										<Setter Property="VerticalContentAlignment" Value="Center" />
										<Setter Property="Template">
											<Setter.Value>
												<ControlTemplate TargetType="{x:Type Button}">
													<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
														<ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
													</Border>
													<ControlTemplate.Triggers>
														<Trigger Property="IsMouseOver" Value="True">
															<Setter TargetName="border" Property="Background" Value="IndianRed" />
															<Setter Property="Foreground" Value="#232324" />
														</Trigger>
														<Trigger Property="IsPressed" Value="True">
															<Setter TargetName="border" Property="Background" Value="#A0A0A0" />
														</Trigger>
													</ControlTemplate.Triggers>
												</ControlTemplate>
											</Setter.Value>
										</Setter>
									</Style>
								</UniformGrid.Resources>
								<Button Content="Clear Schedule" Width="110" Height="24" Background="#993333" Margin="5,0" Click="ClearSchedule_Click" />
								<Button Content="Resync Displays" Width="110" Height="24" Background="#993333" Margin="5,0" Click="ResetBrightness_Click" />
							</UniformGrid>

							<TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,2">
								<Hyperlink Name="AppInfoLink" Foreground="#FF808080" TextDecorations="None" Click="AppInfoLink_Click">
									<Run Text="Info..." FontSize="10" />
								</Hyperlink>
							</TextBlock>
						</Grid>
					</TabItem>
				</TabControl>
			</Grid>
		</Grid>
	</Border>
</Window>