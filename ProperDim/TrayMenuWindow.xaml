<Window x:Class="ProperDim.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProperDim Menu" SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        Opacity="0" 
        Deactivated="Window_Deactivated" Loaded="Window_Loaded">
	<Border Background="#2D2D2D" BorderBrush="#444" BorderThickness="1" CornerRadius="3" Margin="10">
		<Border.Effect>
			<DropShadowEffect BlurRadius="5" Opacity="0.4" ShadowDepth="2"/>
		</Border.Effect>
		<StackPanel Margin="0,4">

			<StackPanel Background="Transparent">
				<TextBlock Text="QuickDim" Foreground="White" Margin="30,8,30,8" FontWeight="SemiBold"/>

				<Slider x:Name="MenuSlider" Minimum="0.01" Maximum="1.0" Height="120" Width="100" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,8" ValueChanged="MenuSlider_ValueChanged" PreviewMouseLeftButtonDown="MenuSlider_PreviewMouseLeftButtonDown" PreviewMouseMove="MenuSlider_PreviewMouseMove" PreviewMouseLeftButtonUp="MenuSlider_PreviewMouseLeftButtonUp">
					<Slider.Style>
						<Style TargetType="Slider">
							<Setter Property="OverridesDefaultStyle" Value="True"/>
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="Slider">
										<Grid Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
											<Grid.RowDefinitions>
												<RowDefinition Height="*" />
												<RowDefinition Height="Auto" />
											</Grid.RowDefinitions>
											<Border Grid.Row="0" Background="#3E3E42" Width="5" CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,6,0,6"/>
											<Track x:Name="PART_Track" Grid.Row="0" HorizontalAlignment="Center" Cursor="Hand">
												<Track.DecreaseRepeatButton>
													<RepeatButton Command="Slider.DecreaseLarge">
														<RepeatButton.Template>
															<ControlTemplate TargetType="{x:Type RepeatButton}">
																<Border Background="Transparent" />
															</ControlTemplate>
														</RepeatButton.Template>
													</RepeatButton>
												</Track.DecreaseRepeatButton>
												<Track.IncreaseRepeatButton>
													<RepeatButton Command="Slider.IncreaseLarge">
														<RepeatButton.Template>
															<ControlTemplate TargetType="{x:Type RepeatButton}">
																<Border Background="Transparent" />
															</ControlTemplate>
														</RepeatButton.Template>
													</RepeatButton>
												</Track.IncreaseRepeatButton>
												<Track.Thumb>
													<Thumb>
														<Thumb.Template>
															<ControlTemplate TargetType="{x:Type Thumb}">
																<Grid Width="18" Height="18">
																	<Ellipse Fill="#B8B8B8" Stroke="#7E7E7E" StrokeThickness="2" Cursor="Hand"/>
																</Grid>
															</ControlTemplate>
														</Thumb.Template>
													</Thumb>
												</Track.Thumb>
											</Track>
											<TextBlock Grid.Row="1" Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:P0}}" Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,1"/>
										</Grid>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</Slider.Style>
				</Slider>
			</StackPanel>

			<Rectangle Height="1" Fill="#80444444" Margin="2,4" HorizontalAlignment="Stretch"/>

			<Button Content="Controls" Click="Controls_Click" Foreground="White" BorderThickness="0" Padding="26,5">
				<Button.Style>
					<Style TargetType="Button">
						<Setter Property="Background" Value="Transparent"/>
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}" Margin="2,2" CornerRadius="2">
										<ContentPresenter Margin="{TemplateBinding Padding}"/>
									</Border>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
						<Style.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#0DFFFFFF"/>
							</Trigger>
						</Style.Triggers>
					</Style>
				</Button.Style>
			</Button>

			<Button Content="Exit" Click="Exit_Click" Foreground="White" BorderThickness="0" Padding="26,5">
				<Button.Style>
					<Style TargetType="Button">
						<Setter Property="Background" Value="Transparent"/>
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}" Margin="2,2" CornerRadius="2">
										<ContentPresenter Margin="{TemplateBinding Padding}"/>
									</Border>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
						<Style.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#0DFFFFFF"/>
							</Trigger>
						</Style.Triggers>
					</Style>
				</Button.Style>
			</Button>
		</StackPanel>
	</Border>
</Window>