<Window x:Class="ProperDim.ScheduleDialog" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:properdim="clr-namespace:ProperDim;assembly=ProperDim"
        Title="Event Scheduler" 
        Height="280" Width="320" 
        MinHeight="280" MaxHeight="280"
        MinWidth="320" MaxWidth="320"
        Background="#2D2D2D" 
        Foreground="#FFFFFFFF" 
        WindowStyle="None" 
        WindowStartupLocation="CenterOwner">
	<WindowChrome.WindowChrome>
		<WindowChrome GlassFrameThickness="1" CornerRadius="0" CaptionHeight="0" UseAeroCaptionButtons="False" ResizeBorderThickness="0" />
	</WindowChrome.WindowChrome>
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}">
				<EventSetter Event="PreviewMouseLeftButtonDown" Handler="ScrollBar_PreviewMouseLeftButtonDown" />
				<EventSetter Event="PreviewMouseLeftButtonUp" Handler="ScrollBar_PreviewMouseLeftButtonUp" />
				<Setter Property="Background" Value="#00FFFFFF" />
				<Setter Property="Width" Value="8" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type ScrollBar}">
							<Grid Name="Bg" Background="#00FFFFFF" SnapsToDevicePixels="True">
								<Track Name="PART_Track" IsEnabled="{TemplateBinding UIElement.IsEnabled}" IsDirectionReversed="True">
									<Track.Thumb>
										<Thumb>
											<Control.Template>
												<ControlTemplate TargetType="{x:Type Thumb}">
													<Border Background="#555555" CornerRadius="4"/>
												</ControlTemplate>
											</Control.Template>
										</Thumb>
									</Track.Thumb>
								</Track>
							</Grid>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="{x:Type Slider}" TargetType="{x:Type Slider}">
				<Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
				<Setter Property="FrameworkElement.OverridesDefaultStyle" Value="True" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type Slider}">
							<Grid Background="#00FFFFFF">
								<Border Name="TrackBackground" Background="#3E3E42" Height="6" CornerRadius="3" VerticalAlignment="Center" Margin="5,0" />
								<Canvas Height="6" Margin="5,0" VerticalAlignment="Center">
									<Rectangle Name="PART_SelectionRange" Fill="{TemplateBinding Control.Foreground}" Height="6" Visibility="Collapsed" />
								</Canvas>
								<Track Name="PART_Track">
									<Track.DecreaseRepeatButton>
										<RepeatButton Command="Slider.DecreaseLarge">
											<RepeatButton.Template>
												<ControlTemplate TargetType="{x:Type RepeatButton}">
													<Border Background="Transparent" />
												</ControlTemplate>
											</RepeatButton.Template>
										</RepeatButton>
									</Track.DecreaseRepeatButton>
									<Track.IncreaseRepeatButton>
										<RepeatButton Command="Slider.IncreaseLarge">
											<RepeatButton.Template>
												<ControlTemplate TargetType="{x:Type RepeatButton}">
													<Border Background="Transparent" />
												</ControlTemplate>
											</RepeatButton.Template>
										</RepeatButton>
									</Track.IncreaseRepeatButton>
									<Track.Thumb>
										<Thumb Name="Thumb">
											<Thumb.Template>
												<ControlTemplate TargetType="{x:Type Thumb}">
													<Ellipse Fill="#B8B8B8" Width="18" Height="18" Stroke="#7E7E7E" StrokeThickness="2" Cursor="Hand" />
												</ControlTemplate>
											</Thumb.Template>
										</Thumb>
									</Track.Thumb>
								</Track>
							</Grid>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="{x:Type ComboBox}" TargetType="{x:Type ComboBox}">
				<Setter Property="Background" Value="#3E3E42" />
				<Setter Property="Foreground" Value="#FFFFFFFF" />
				<Setter Property="BorderBrush" Value="#3F3F46" />
				<Setter Property="BorderThickness" Value="1" />
				<Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
				<Setter Property="FrameworkElement.OverridesDefaultStyle" Value="True" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type ComboBox}">
							<Grid>
								<ToggleButton Name="ToggleButton" BorderBrush="{TemplateBinding Control.BorderBrush}" Background="{TemplateBinding Control.Background}" Foreground="{TemplateBinding Control.Foreground}" Focusable="False" ClickMode="Press" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
									<Control.Template>
										<ControlTemplate TargetType="{x:Type ToggleButton}">
											<Border Name="Border" CornerRadius="2" Background="#3E3E42" BorderBrush="#3F3F46" BorderThickness="1">
												<Path Name="Arrow" Fill="#FFFFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" Data="M0,0 L4,4 L8,0" />
											</Border>
										</ControlTemplate>
									</Control.Template>
								</ToggleButton>
								<ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding ComboBox.SelectionBoxItem}" Margin="10,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
								<Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding ComboBox.IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
									<Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding FrameworkElement.ActualWidth}" MaxHeight="{TemplateBinding ComboBox.MaxDropDownHeight}">
										<Border Name="DropDownBorder" Background="#2D2D2D" BorderThickness="1" BorderBrush="#3F3F46" />
										<ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True" PreviewMouseWheel="DropDownScrollViewer_PreviewMouseWheel" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
											<StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
										</ScrollViewer>
									</Grid>
								</Popup>
							</Grid>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style TargetType="{x:Type ComboBoxItem}">
				<Setter Property="Background" Value="Transparent" />
				<Setter Property="Foreground" Value="White" />
				<Setter Property="Padding" Value="5,2" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type ComboBoxItem}">
							<Border Name="ItemBorder" Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="2" Margin="2,1">
								<ContentPresenter Margin="{TemplateBinding Padding}" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="ItemBorder" Property="Background" Value="#3c3c3e" />
								</Trigger>
								<Trigger Property="IsSelected" Value="True">
									<Setter TargetName="ItemBorder" Property="Background" Value="#555555" />
									<Setter Property="Foreground" Value="White" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="{x:Type CheckBox}" TargetType="{x:Type CheckBox}">
				<Setter Property="Foreground" Value="#FFFFFFFF" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type CheckBox}">
							<BulletDecorator Background="#00FFFFFF">
								<BulletDecorator.Bullet>
									<Grid Width="16" Height="16">
										<Border Name="BoxBorder" Background="#3E3E42" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="2"/>
										<Path Name="CheckMark" Visibility="Collapsed" Data="M3,8 L6,11 L13,4" Stroke="#D3D3D3" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
									</Grid>
								</BulletDecorator.Bullet>
								<ContentPresenter Margin="5,0,0,0" VerticalAlignment="Center" />
							</BulletDecorator>
							<ControlTemplate.Triggers>
								<Trigger Property="ToggleButton.IsChecked" Value="True">
									<Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
								</Trigger>
								<Trigger Property="UIElement.IsMouseOver" Value="True">
									<Setter TargetName="BoxBorder" Property="Border.BorderBrush" Value="#6D6D72" />
									<Setter TargetName="BoxBorder" Property="Border.Background" Value="#454549" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Border Background="#2D2D2D" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
		<DockPanel>
			<Border DockPanel.Dock="Top" Height="32" Background="#1E1E1E" CornerRadius="7,7,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
				<Grid>
					<TextBlock Text="Event Scheduler" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#AAAAAA" FontSize="12" IsHitTestVisible="False" />
					<Button Content="✕" HorizontalAlignment="Right" Width="32" Height="32" Foreground="#FFFFFFFF" BorderThickness="0" Click="Close_Click">
						<FrameworkElement.Style>
							<Style TargetType="{x:Type Button}">
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="{x:Type Button}">
											<Border Name="Root" Background="#00FFFFFF" CornerRadius="0,7,0,0">
												<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="UIElement.IsMouseOver" Value="True">
													<Setter TargetName="Root" Property="Border.Background" Value="#E81123" />
												</Trigger>
												<Trigger Property="IsPressed" Value="True">
													<Setter TargetName="Root" Property="Border.Background" Value="#C50F1F" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</FrameworkElement.Style>
					</Button>
				</Grid>
			</Border>
			<StackPanel Margin="20,10,20,15">
				<TextBlock Text="Time" Margin="0,0,0,4" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" />
				<StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
					<ComboBox Name="HourBox" Width="65" Margin="0,0,5,0" SelectionChanged="TimeSelection_Changed" Focusable="False" />
					<TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold" />
					<ComboBox Name="MinuteBox" Width="65" Margin="0,0,5,0" SelectionChanged="TimeSelection_Changed" Focusable="False" />
					<Border Name="AmPmContainer" Width="65" Background="#3E3E42" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="3">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<RadioButton Name="AmRadio" Grid.Column="0" GroupName="AmPm" Cursor="Hand" Focusable="False" Click="AmPmRadio_Click">
								<RadioButton.Template>
									<ControlTemplate TargetType="{x:Type RadioButton}">
										<Border Name="AmBg" Background="Transparent" CornerRadius="2,0,0,2">
											<TextBlock Name="AmText" Text="AM" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF808080" FontWeight="Normal" FontSize="11" Opacity="0.5"/>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger Property="IsChecked" Value="True">
												<Setter TargetName="AmBg" Property="Background" Value="#555555"/>
												<Setter TargetName="AmText" Property="Foreground" Value="LightGray"/>
												<Setter TargetName="AmText" Property="FontWeight" Value="SemiBold"/>
												<Setter TargetName="AmText" Property="Opacity" Value="1.0"/>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</RadioButton.Template>
							</RadioButton>

							<RadioButton Name="PmRadio" Grid.Column="1" GroupName="AmPm" Cursor="Hand" Focusable="False" Click="AmPmRadio_Click">
								<RadioButton.Template>
									<ControlTemplate TargetType="{x:Type RadioButton}">
										<Border Name="PmBg" Background="Transparent" CornerRadius="0,2,2,0">
											<TextBlock Name="PmText" Text="PM" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF808080" FontWeight="Normal" FontSize="11" Opacity="0.5"/>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger Property="IsChecked" Value="True">
												<Setter TargetName="PmBg" Property="Background" Value="#555555"/>
												<Setter TargetName="PmText" Property="Foreground" Value="LightGray"/>
												<Setter TargetName="PmText" Property="FontWeight" Value="SemiBold"/>
												<Setter TargetName="PmText" Property="Opacity" Value="1.0"/>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</RadioButton.Template>
							</RadioButton>
						</Grid>
					</Border>
				</StackPanel>
				<CheckBox Name="Is24hCheck" Content="Use 24-hour clock" Foreground="LightGray" Margin="4,0,0,12" HorizontalAlignment="Left" Checked="Is24hCheck_Changed" Unchecked="Is24hCheck_Changed" />
				<Border Background="#00FFFFFF" Margin="0,0,0,2">
					<StackPanel>
						<StackPanel Orientation="Horizontal" Margin="0,0,0,2" HorizontalAlignment="Center">
							<TextBlock Text="Brightness: " FontWeight="Bold" IsHitTestVisible="False" />
							<TextBlock Name="BrightnessLabel" IsHitTestVisible="False" Text="{Binding ElementName=DialogDimmerSlider, Path=Value, StringFormat={}{0:P0}}" />
						</StackPanel>
						<Border Background="#00FFFFFF">
							<Slider Name="DialogDimmerSlider" Height="32" Background="#00FFFFFF" Minimum="0.05" Maximum="1.0" Value="1.0" IsDirectionReversed="False" ValueChanged="DialogSlider_ValueChanged" PreviewMouseWheel="DialogDimmerSlider_PreviewMouseWheel" PreviewMouseLeftButtonDown="DialogDimmerSlider_PreviewMouseLeftButtonDown" PreviewMouseMove="DialogDimmerSlider_PreviewMouseMove" PreviewMouseLeftButtonUp="DialogDimmerSlider_PreviewMouseLeftButtonUp" />
						</Border>
					</StackPanel>
				</Border>
				<TextBlock Text="Days Active" Margin="0,0,0,8" FontWeight="Bold" HorizontalAlignment="Center" />
				<UniformGrid Columns="7" Margin="0,0,0,15">
					<CheckBox Name="DayM" Content="M" IsChecked="True" HorizontalAlignment="Center" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed" />
					<CheckBox Name="DayT" Content="T" IsChecked="True" HorizontalAlignment="Center" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed" />
					<CheckBox Name="DayW" Content="W" IsChecked="True" HorizontalAlignment="Center" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed" />
					<CheckBox Name="DayTh" Content="Th" IsChecked="True" HorizontalAlignment="Center" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed" />
					<CheckBox Name="DayF" Content="F" IsChecked="True" HorizontalAlignment="Center" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed" />
					<CheckBox Name="DayS" Content="S" IsChecked="True" HorizontalAlignment="Center" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed" />
					<CheckBox Name="DaySu" Content="Su" IsChecked="True" HorizontalAlignment="Center" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed" />
				</UniformGrid>
				<Button Name="ActionButton" Content="Add to Schedule" Background="#3E3E42" Foreground="#FFFFFFFF" Height="25" Padding="20,0" HorizontalAlignment="Center" BorderBrush="#3F3F46" Cursor="Hand" Click="Add_Click" Margin="0,5,0,0">
					<Control.Template>
						<ControlTemplate TargetType="{x:Type Button}">
							<Border Name="BtnBorder" Background="{TemplateBinding Control.Background}" BorderBrush="#555" BorderThickness="1" CornerRadius="0">
								<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Control.Padding}" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="UIElement.IsMouseOver" Value="True">
									<Setter TargetName="BtnBorder" Property="Border.Background" Value="#4E4E52" />
									<Setter TargetName="BtnBorder" Property="Border.BorderBrush" Value="#6D6D72" />
								</Trigger>
								<Trigger Property="ButtonBase.IsPressed" Value="True">
									<Setter TargetName="BtnBorder" Property="Border.Background" Value="#2D2D2D" />
								</Trigger>
								<Trigger Property="UIElement.IsEnabled" Value="False">
									<Setter Property="UIElement.Opacity" Value="0.5" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Control.Template>
				</Button>
			</StackPanel>
		</DockPanel>
	</Border>
</Window>